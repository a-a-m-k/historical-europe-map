{
  "name": "historical-europe-map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://a-a-m-k.github.io/historical-europe-map",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/postbuild-csp-cleanup.cjs",
    "build:check": "npm run build && node scripts/check-bundle-size.js",
    "build:analyze": "vite build && echo 'Bundle analysis generated at dist/bundle-analysis.html'",
    "preview": "vite preview",
    "test:base": "NODE_OPTIONS=--max-old-space-size=4096 vitest",
    "test": "npm run test:base",
    "test:ui": "npm run test:base -- --ui",
    "test:run": "npm run test:base -- run",
    "test:run:strict-warnings": "FAIL_ON_TEST_WARNINGS=1 npm run test:base -- run",
    "test:coverage": "node scripts/run-vitest-coverage.cjs --profile=local",
    "test:coverage:ci": "node scripts/run-vitest-coverage.cjs --profile=ci --ci-reporter --ratchet",
    "test:visual": "playwright test tests/e2e/visual-zoom.spec.ts",
    "capture:hero": "node scripts/capture-hero.cjs",
    "pretest:e2e": "node scripts/ensure-playwright-chromium.cjs",
    "test:e2e": "playwright test tests/e2e --grep-invert @visual",
    "test:e2e:prod": "E2E_SERVER_MODE=preview playwright test tests/e2e --grep-invert @visual",
    "test:e2e:install": "playwright install chromium",
    "test:unit": "npm run test:base -- run tests/unit",
    "test:integration": "npm run test:base -- run tests/integration",
    "test:pyramid": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "verify:ci": "npm run lint:check && npm run lint:css-boundaries && npm run typecheck && npm run test:integration && npm run test:coverage:ci && node scripts/build-gh-pages.cjs && node scripts/check-built-html.cjs && node scripts/check-bundle-size.js",
    "verify:csp": "npm run build && node scripts/verify-csp.cjs",
    "zoom:report": "tsx scripts/generateZoomReport.ts",
    "generate:terrain-dark": "node scripts/generate-terrain-dark.mjs",
    "prepare": "husky",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.{ts,tsx}\" \"vite-plugin-*.ts\" \"vite.config.ts\" \"vitest.config.ts\" \"playwright.config.ts\" \"eslint.config.ts\"",
    "lint:css-boundaries": "node scripts/check-index-css-boundaries.cjs",
    "lint:staged": "npx lint-staged",
    "lint:check": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.{ts,tsx}\" \"vite-plugin-*.ts\" \"vite.config.ts\" \"vitest.config.ts\" \"playwright.config.ts\" \"eslint.config.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "format": "prettier --write . && npm run lint -- --fix",
    "predeploy": "node scripts/build-gh-pages.cjs",
    "deploy": "gh-pages -d dist"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "html2canvas": "^1.4.1",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "^8.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.0 <10",
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "critical": "^7.2.0",
    "eslint": "^9.39.0 <10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "gh-pages": "^6.3.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "terser": "^5.44.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "glob": ">=11.0.0",
    "flatted": ">=3.4.2",
    "svgo": ">=3.3.3",
    "undici": ">=7.24.0"
  }
}
